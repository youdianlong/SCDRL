{
  "source_datasets": [
    "wisconsin",
    "texas",
    "cornell",
    "chameleon",
    "squirrel",
    "cora",
    "citeseer",
    "pubmed",
    "computers"
  ],
  "task": "node",
  "cache_dir": "storage/.cache",
  "save_dir": "storage/UCDRL/pretrained_model",
  "seed": 777,
  "node_feature_dim": 100,
  "reconstruct": 0.2,
  "backbone": "MoE",
  "hid_dim": 128,
  "moe_num_conv_layers": 2,
  "moe_dropout": 0.2,
  "moe_epsilon": 0.1,
  "moe_num_experts": 10,
  "moe_tau": 1.0,
  "moe_reg_lambda": 0.01,
  "saliency_model": "none",
  "pretrain_method": "ucdrl_pretrain",
  "lr": 0.01,
  "weight_decay": 0.00001,
  "epochs": 100,
  "batch_size": 10,
  "noise_switch": false,
  "cross_link": 1,
  "cross_link_ablation": false,
  "dynamic_edge": "none",
  "dynamic_prune": 0.1,
  "cl_init_method": "learnable",
  "split_method": "RandomWalk",
  "lambda_causal": 1.0,
  "lambda_env": 0.5,
  "lambda_rec": 0.1,
  "lambda_cons": 0.05,
  "lambda_eps": 0.01,
  "lambda_cfd": 0.2
}
